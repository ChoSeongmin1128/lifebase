{
  "name": "@lifebase/server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "go run ./cmd/server/",
    "build": "go build -o dist/server ./cmd/server/",
    "lint": "go vet ./...",
    "test": "go test ./...",
    "clean": "rm -rf dist/ tmp/",
    "backup:db": "go run ./cmd/db-backup/",
    "backup:db:auto": "bash ../../scripts/backup-db.sh",
    "backup:db:check": "bash ../../scripts/check-recent-db-backup.sh",
    "restore:db": "go run ./cmd/db-restore/",
    "migrate:up": "bash ../../scripts/check-recent-db-backup.sh && goose -dir migrations postgres \"$DATABASE_URL\" up",
    "migrate:down": "bash ../../scripts/check-recent-db-backup.sh && goose -dir migrations postgres \"$DATABASE_URL\" down",
    "migrate:status": "goose -dir migrations postgres \"$DATABASE_URL\" status",
    "migrate:create": "goose -dir migrations create"
  }
}
