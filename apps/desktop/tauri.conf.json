{
  "$schema": "https://raw.githubusercontent.com/niceatom/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "LifeBase",
  "version": "0.1.0",
  "identifier": "cc.lifebase.desktop",
  "build": {
    "frontendDist": "../web/out",
    "devUrl": "http://localhost:39001"
  },
  "app": {
    "windows": [
      {
        "title": "LifeBase",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
