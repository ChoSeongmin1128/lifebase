# LifeBase production environment example
SERVER_ENV=production

# PostgreSQL
DATABASE_URL=postgres://USER:PASSWORD@DB_HOST:5432/lifebase?sslmode=require

# Redis
REDIS_URL=redis://REDIS_HOST:6379

# Google OAuth (production)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT
JWT_SECRET=replace-with-strong-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=720h

# Server
SERVER_PORT=38117

# File Storage
STORAGE_DATA_PATH=/var/lib/lifebase/data
STORAGE_THUMB_PATH=/var/lib/lifebase/thumbs

# Domain
DOMAIN=lifebase.cc
WEB_URL=https://lifebase.cc
ADMIN_URL=https://admin.lifebase.cc
API_URL=https://api.lifebase.cc
STATE_HMAC_KEY=replace-with-strong-random-hmac-key
